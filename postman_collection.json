          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "20" },
            { "key": "providerId", "value": "7" }
          ]
        }
      }
    },
    {
      "name": "Get Games by Provider - TurboGames",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/games?page=1&limit=20&providerId=58",
