{
  "info": {
    "name": "Casino Games API v2",
    "description": "API collection for testing OCGames Backend Endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Sync Games",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "x-api-key",
            "value": "super-secret-casino-key-2026",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/games/sync",
          "host": ["{{baseUrl}}"],
          "path": ["api", "games", "sync"]
        }
      }
    },
    {
      "name": "Get Games (Search & Filters)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/games?page=1&limit=20",
          "host": ["{{baseUrl}}"],
          "path": ["api", "games"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "20" },
            { "key": "search", "value": "roulette", "disabled": true },
            { "key": "type", "value": "SLOTS", "disabled": true },
            { "key": "type", "value": "LIVE", "disabled": true },
            { "key": "providerId", "value": "4", "description": "PragmaticPlay", "disabled": true },
            { "key": "providerId", "value": "7", "description": "Fugaso", "disabled": true },
            { "key": "providerId", "value": "58", "description": "TurboGames", "disabled": true },
            { "key": "providerId", "value": "64", "description": "PGSoft", "disabled": true },
            { "key": "isLive", "value": "true", "disabled": true }
          ]
        }
      }
    },
    {
      "name": "Get Games by Provider - PragmaticPlay",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/games?page=1&limit=20&providerId=4",
          "host": ["{{baseUrl}}"],
          "path": ["api", "games"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "20" },
            { "key": "providerId", "value": "4" }
          ]
        }
      }
    },
    {
